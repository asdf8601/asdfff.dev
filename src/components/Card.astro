---
interface Props {
  title?: string
  type?: "default" | "info" | "warning" | "success" | "error"
}

const { title, type = "default" } = Astro.props
---

<div class={`card card-${type}`}>
  {title && <div class="card-title">{title}</div>}
  <div class="card-content">
    <slot />
  </div>
</div>

<style>
  .card {
    margin-bottom: var(--spacing-lg);
    padding: var(--spacing-sm) var(--spacing-md);
    border-left: 2px solid var(--color-accent);
    border-bottom: 1px solid var(--color-border);
  }

  .card-title {
    color: var(--color-accent);
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: var(--spacing-xs);
    text-transform: uppercase;
  }

  .card-content :global(p:last-child) {
    margin-bottom: 0;
  }

  .card-content :global(ul),
  .card-content :global(ol) {
    margin-left: var(--spacing-md);
    padding-left: 0;
  }

  .card-content :global(ul li),
  .card-content :global(ol li) {
    margin-bottom: var(--spacing-xs);
  }

  .card-info {
    border-left-color: #0088ff;
  }

  .card-info .card-title {
    color: #0088ff;
  }

  .card-warning {
    border-left-color: #ffaa00;
  }

  .card-warning .card-title {
    color: #ffaa00;
  }

  .card-success {
    border-left-color: var(--color-accent);
  }

  .card-success .card-title {
    color: var(--color-accent);
  }

  .card-error {
    border-left-color: #ff0000;
  }

  .card-error .card-title {
    color: #ff0000;
  }
</style>

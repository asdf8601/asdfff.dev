---
import BaseLayout from "./BaseLayout.astro"
import PageSearchModal from "../components/PageSearchModal.astro"

const { frontmatter } = Astro.props
const title = frontmatter?.title || "Untitled"
const description = frontmatter?.description
---

<BaseLayout title={`${title} - wtfm`} description={description}>
  <article>
    <h1>{title}</h1>
    {
      frontmatter?.date && (
        <time class="post-date" datetime={frontmatter.date}>
          {new Date(frontmatter.date).toLocaleDateString("en-US", {
            year: "numeric",
            month: "long",
            day: "numeric",
          })}
        </time>
      )
    }
    <slot />
  </article>

  <script is:inline>
    if (document.querySelector("pre.mermaid")) {
      const s = document.createElement("script")
      s.src = "https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.min.js"
      s.onload = () => {
        const isDark = document.documentElement.getAttribute("data-theme") === "dark"
        const palette = isDark
          ? {
              background: "#282828",
              primaryColor: "#3c3836",
              primaryTextColor: "#ebdbb2",
              primaryBorderColor: "#665c54",
              lineColor: "#a89984",
              secondaryColor: "#504945",
              tertiaryColor: "#32302f",
              mainBkg: "#3c3836",
              nodeBorder: "#665c54",
              clusterBkg: "#32302f",
              clusterBorder: "#665c54",
              titleColor: "#b8bb26",
              edgeLabelBackground: "#282828",
              textColor: "#ebdbb2",
            }
          : {
              background: "#f1f1f1",
              primaryColor: "#fafafa",
              primaryTextColor: "#2a2a2a",
              primaryBorderColor: "#bcbcbc",
              lineColor: "#6a6a6a",
              secondaryColor: "#e6e6e6",
              tertiaryColor: "#f5f5f5",
              mainBkg: "#fafafa",
              nodeBorder: "#bcbcbc",
              clusterBkg: "#f5f5f5",
              clusterBorder: "#bcbcbc",
              titleColor: "#79740e",
              edgeLabelBackground: "#f1f1f1",
              textColor: "#2a2a2a",
            }
        mermaid.initialize({
          startOnLoad: false,
          theme: "base",
          themeVariables: palette,
        })
        mermaid.run({ querySelector: "pre.mermaid" }).catch(err => console.error("mermaid:", err))
      }
      document.head.appendChild(s)
    }
  </script>

  <PageSearchModal />
</BaseLayout>

<style>
  article {
    max-width: 100%;
  }

  article h1 {
    margin-bottom: var(--spacing-sm);
  }

  .post-date {
    display: block;
    color: var(--color-text-muted);
    font-size: 0.85rem;
    margin-bottom: var(--spacing-lg);
  }
</style>

<script>
  let gCount = 0
  let gTimer: number | undefined
  let escapeCount = 0
  let escapeTimer: number | undefined

  document.addEventListener("keydown", e => {
    const handlers = (window as any).pageSearchHandlers
    if (handlers?.isPageSearchActive()) {
      if (e.key === "Escape") {
        e.preventDefault()
        e.stopImmediatePropagation()
        handlers.closePageSearch()
      }
      return
    }

    if (e.target instanceof HTMLInputElement || e.target instanceof HTMLTextAreaElement) return

    if (e.key === "/" && !e.ctrlKey && !e.metaKey) {
      e.preventDefault()
      handlers?.openPageSearch()
    } else if (e.key === "j") {
      e.preventDefault()
      window.scrollBy({ top: 100, behavior: "smooth" })
    } else if (e.key === "k" && !(e.ctrlKey || e.metaKey)) {
      e.preventDefault()
      window.scrollBy({ top: -100, behavior: "smooth" })
    } else if (e.key === "g") {
      gCount++
      if (gCount === 1) {
        gTimer = window.setTimeout(() => {
          gCount = 0
        }, 500)
      } else if (gCount === 2) {
        e.preventDefault()
        if (gTimer) clearTimeout(gTimer)
        window.scrollTo({ top: 0, behavior: "smooth" })
        gCount = 0
      }
    } else if (e.key === "G") {
      e.preventDefault()
      window.scrollTo({ top: document.body.scrollHeight, behavior: "smooth" })
    } else if (e.key === "Escape") {
      escapeCount++
      if (escapeCount === 1) {
        escapeTimer = window.setTimeout(() => {
          escapeCount = 0
        }, 500)
      } else if (escapeCount === 2) {
        if (escapeTimer) clearTimeout(escapeTimer)
        window.location.href = "/posts"
      }
    }
  })
</script>

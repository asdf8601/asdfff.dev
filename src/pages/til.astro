---
import BaseLayout from "../layouts/BaseLayout.astro"
import PageSearchModal from "../components/PageSearchModal.astro"

const tilModules = import.meta.glob("./til/*.md", { eager: true })
const tils = Object.values(tilModules)

const sortedTils = tils.sort((a, b) => {
  const dateA = new Date(a.frontmatter.date || 0)
  const dateB = new Date(b.frontmatter.date || 0)
  return dateB.getTime() - dateA.getTime()
})
---

<BaseLayout title="til - wtfm">
  <article>
    <h1>til</h1>

    <p>Today I learned. Short notes. No fluff.</p>

    {
      sortedTils.length > 0 ? (
        <div class="timeline">
          {sortedTils.map((til, index) => {
            const tilNumber = sortedTils.length - index
            const date = new Date(til.frontmatter.date)
            const dateKey = date.toISOString().slice(0, 10)
            const prevDateKey =
              index > 0
                ? new Date(sortedTils[index - 1].frontmatter.date).toISOString().slice(0, 10)
                : null
            const isFirstOfDay = dateKey !== prevDateKey
            const formattedDate = date.toLocaleDateString("en-US", {
              year: "numeric",
              month: "short",
              day: "numeric",
            })
            return (
              <div class="tl-entry" id={`til-${tilNumber}`}>
                <div class="tl-date">
                  {isFirstOfDay ? <time>{formattedDate}</time> : <span class="tl-same-day" />}
                  <span class="tl-number">#{tilNumber}</span>
                </div>
                <a href={`#til-${tilNumber}`} class="tl-pipe" aria-label="Link to this TIL" />
                <div class="tl-content">
                  <til.Content />
                </div>
              </div>
            )
          })}
        </div>
      ) : (
        <p class="empty-state">No TILs yet. Add markdown files to src/pages/til/</p>
      )
    }
  </article>

  <PageSearchModal />
</BaseLayout>

<style>
  h1 {
    margin-bottom: var(--spacing-md);
    text-transform: lowercase;
  }

  .timeline {
    display: flex;
    flex-direction: column;
  }

  .tl-entry {
    display: grid;
    grid-template-columns: 7rem 2rem 1fr;
    scroll-margin-top: var(--spacing-md);
    transition: background-color 0.2s ease;
  }

  .tl-date {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    padding-top: var(--spacing-md);
    padding-right: var(--spacing-sm);
    gap: 0.125rem;
  }

  .tl-date time {
    color: var(--color-text-muted);
    font-size: 0.8rem;
    white-space: nowrap;
  }

  .tl-number {
    color: var(--color-accent);
    font-size: 0.75rem;
    font-weight: 600;
  }

  .tl-pipe {
    position: relative;
    display: flex;
    justify-content: center;
    cursor: pointer;
    text-decoration: none;
  }

  .tl-pipe::before {
    content: "";
    position: absolute;
    top: 0;
    bottom: 0;
    width: 1px;
    background-color: var(--color-border);
    opacity: 0.5;
  }

  .tl-pipe::after {
    content: "";
    position: absolute;
    top: calc(var(--spacing-md) + 0.1rem);
    width: 11px;
    height: 11px;
    border: 1px solid var(--color-border);
    background-color: var(--color-bg);
    border-radius: 50%;
    transition:
      border-color 0.2s,
      background-color 0.2s,
      box-shadow 0.2s;
  }

  .tl-pipe:hover::after {
    border-color: var(--color-accent);
    background-color: var(--color-accent);
    box-shadow: 0 0 6px 1px var(--color-accent);
  }

  .tl-entry:first-child .tl-pipe::before {
    top: var(--spacing-md);
  }

  .tl-entry:last-child .tl-pipe::before {
    bottom: 50%;
  }

  .tl-content {
    padding: var(--spacing-md) 0 var(--spacing-xl) var(--spacing-md);
    position: relative;
    border-bottom: 1px solid var(--color-border);
  }

  .tl-entry:last-child .tl-content {
    border-bottom: none;
  }

  .tl-content :global(p) {
    margin-bottom: 0;
  }

  .tl-content :global(p + p) {
    margin-top: var(--spacing-sm);
  }

  .tl-content :global(ul) {
    margin-bottom: 0;
  }

  .tl-entry:hover .tl-pipe::after {
    border-color: var(--color-accent);
    background-color: var(--color-accent);
  }

  .tl-entry:target .tl-pipe::after {
    border-color: var(--color-accent);
    background-color: var(--color-accent);
  }

  .tl-entry:target .tl-date time {
    color: var(--color-accent);
  }

  .tl-entry.selected-item .tl-pipe::after {
    border-color: var(--color-accent);
    background-color: var(--color-accent);
  }

  .tl-entry.selected-item .tl-date time {
    color: var(--color-accent);
  }

  @media (max-width: 768px) {
    .tl-entry {
      grid-template-columns: 1fr;
    }

    .tl-date {
      flex-direction: row;
      align-items: center;
      padding: var(--spacing-sm) 0 0 0;
      gap: var(--spacing-sm);
    }

    .tl-pipe {
      display: none;
    }

    .tl-content {
      padding: var(--spacing-sm) 0 var(--spacing-md) 0;
      border-left: 2px solid var(--color-border);
      padding-left: var(--spacing-md);
    }

    .tl-entry:hover .tl-content,
    .tl-entry:target .tl-content,
    .tl-entry.selected-item .tl-content {
      border-left-color: var(--color-accent);
    }
  }
</style>

<script>
  const { openPageSearch, isPageSearchActive } = (window as any).pageSearchHandlers

  document.addEventListener("DOMContentLoaded", () => {
    const tilLinks = document.querySelectorAll(".tl-pipe")

    tilLinks.forEach(link => {
      link.addEventListener("click", async e => {
        e.preventDefault()
        const href = link.getAttribute("href")

        if (href) {
          const fullUrl = window.location.origin + window.location.pathname + href

          try {
            await navigator.clipboard.writeText(fullUrl)
            ;(window as any).showNotification?.("link copied")
          } catch (err) {
            console.error("Failed to copy link:", err)
          }
        }
      })
    })

    const tilEntries = Array.from(document.querySelectorAll(".tl-entry"))
    let selectedIndex = -1

    function selectItem(index: number) {
      tilEntries.forEach(entry => entry.classList.remove("selected-item"))
      if (index >= 0 && index < tilEntries.length) {
        selectedIndex = index
        tilEntries[selectedIndex].classList.add("selected-item")
        tilEntries[selectedIndex].scrollIntoView({ behavior: "smooth", block: "center" })
      }
    }

    document.addEventListener("keydown", e => {
      const target = e.target as HTMLElement

      if (isPageSearchActive()) {
        return
      }

      if (target.tagName === "INPUT" || target.tagName === "TEXTAREA") {
        return
      }

      if (e.key === "k" && (e.ctrlKey || e.metaKey)) {
        return
      }

      if (e.key === "/") {
        e.preventDefault()
        openPageSearch()
        return
      }

      if (e.key === "j") {
        e.preventDefault()
        selectItem(selectedIndex + 1)
      } else if (e.key === "k") {
        e.preventDefault()
        if (selectedIndex > 0) {
          selectItem(selectedIndex - 1)
        }
      } else if (e.key === "Enter" && selectedIndex >= 0) {
        e.preventDefault()
        const link = tilEntries[selectedIndex].querySelector(".tl-pipe") as HTMLAnchorElement
        if (link) {
          link.click()
        }
      }
    })
  })
</script>

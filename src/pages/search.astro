---
import BaseLayout from "../layouts/BaseLayout.astro"
---

<BaseLayout title="search - wtfm">
  <article>
    <h1>search</h1>

    <form id="search-form" action="/search" method="get" role="search" class="search-page-form">
      <input
        type="search"
        id="search-page-input"
        name="q"
        placeholder="search posts, til, quotes..."
        aria-label="Search"
        autofocus
      />
    </form>

    <p id="search-summary" class="summary"></p>
    <div id="search-results" class="results"></div>
  </article>
</BaseLayout>

<style>
  h1 {
    margin-bottom: var(--spacing-md);
    text-transform: lowercase;
  }

  .search-page-form {
    margin-bottom: var(--spacing-md);
  }

  #search-page-input {
    width: 100%;
    background-color: var(--color-bg);
    border: 1px solid var(--color-border);
    color: var(--color-text);
    font-family: var(--font-mono);
    font-size: 1rem;
    padding: 0.6rem 0.85rem;
    outline: none;
  }

  #search-page-input:focus {
    border-color: var(--color-accent);
  }

  .summary {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    margin-bottom: var(--spacing-md);
  }

  .results {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }

  .result-item {
    padding-bottom: 0;
  }

  .result-item h2 {
    margin: 0 0 var(--spacing-xs) 0;
    font-size: 1.15rem;
    font-weight: 500;
  }

  .result-item h2 a {
    text-decoration: none;
  }

  .result-item h2 a:hover {
    text-decoration: underline;
  }

  .result-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.4rem;
    font-size: 0.8rem;
    color: var(--color-text-muted);
    opacity: 0.85;
  }

  .result-meta .section {
    text-transform: lowercase;
    border: 1px solid var(--color-border);
    padding: 0 0.4rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
  }

  .result-meta .separator {
    opacity: 0.4;
  }

  .result-meta .tag {
    white-space: nowrap;
    border: 1px solid var(--color-border);
    padding: 0 0.4rem;
    border-radius: 3px;
    font-size: 0.72rem;
    line-height: 1.6;
  }

  .result-meta .hash {
    opacity: 0.5;
    margin-right: 1px;
  }

  .result-excerpt {
    color: var(--color-text);
    font-size: 0.9rem;
    line-height: 1.6;
    opacity: 0.9;
  }

  .result-excerpt :global(mark),
  .result-item h2 :global(mark) {
    background-color: var(--color-accent);
    color: var(--color-bg);
    padding: 0 2px;
  }

  .empty,
  .hint {
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }
</style>

<script>
  interface PageData {
    url: string
    title: string
    date?: string
    category?: string
    tags?: string[]
    content: string
  }

  interface ScoredResult extends PageData {
    score: number
  }

  const params = new URLSearchParams(window.location.search)
  const query = (params.get("q") || "").trim()
  const input = document.getElementById("search-page-input") as HTMLInputElement
  const summary = document.getElementById("search-summary") as HTMLParagraphElement
  const resultsEl = document.getElementById("search-results") as HTMLDivElement

  if (input && query) input.value = query

  function escapeHtml(s: string): string {
    return s
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#39;")
  }

  function escapeRegex(s: string): string {
    return s.replace(/[.*+?^${}()|[\]\\]/g, "\\$&")
  }

  function tokenize(q: string): string[] {
    return q
      .toLowerCase()
      .split(/\s+/)
      .map(t => t.trim())
      .filter(t => t.length > 0)
  }

  function highlight(text: string, tokens: string[]): string {
    const safe = escapeHtml(text)
    if (tokens.length === 0) return safe
    const re = new RegExp(`(${tokens.map(escapeRegex).join("|")})`, "ig")
    return safe.replace(re, "<mark>$1</mark>")
  }

  function getExcerpt(content: string, tokens: string[]): string {
    if (!tokens.length) return content.slice(0, 220) + "..."
    const lc = content.toLowerCase()
    let best = -1
    for (const t of tokens) {
      const i = lc.indexOf(t)
      if (i !== -1 && (best === -1 || i < best)) best = i
    }
    if (best === -1) return content.slice(0, 220) + "..."
    const start = Math.max(0, best - 100)
    const end = Math.min(content.length, best + 200)
    let ex = content.slice(start, end)
    if (start > 0) ex = "..." + ex
    if (end < content.length) ex = ex + "..."
    return ex
  }

  function sectionFromUrl(url: string): string {
    if (url.startsWith("/posts/")) return "post"
    if (url.startsWith("/til/")) return "til"
    if (url.startsWith("/quotes/")) return "quote"
    if (url === "/posts") return "page"
    return "page"
  }

  function score(page: PageData, tokens: string[]): number {
    if (!tokens.length) return 0
    const t = page.title.toLowerCase()
    const c = page.content.toLowerCase()
    const tagsStr = (page.tags || []).join(" ").toLowerCase()
    const cat = (page.category || "").toLowerCase()
    let s = 0
    for (const tok of tokens) {
      let any = false
      if (t.includes(tok)) {
        s += 10
        any = true
      }
      if (tagsStr.includes(tok)) {
        s += 5
        any = true
      }
      if (cat.includes(tok)) {
        s += 4
        any = true
      }
      if (c.includes(tok)) {
        // count occurrences (cap)
        const m = c.match(new RegExp(escapeRegex(tok), "g"))
        s += Math.min(m ? m.length : 0, 8)
        any = true
      }
      if (!any) return 0 // require every token to match somewhere
    }
    // boost exact phrase
    const phrase = tokens.join(" ")
    if (t.includes(phrase)) s += 15
    if (c.includes(phrase)) s += 5
    return s
  }

  function formatDate(d: string): string {
    if (!d) return ""
    const dt = new Date(d)
    if (isNaN(dt.getTime())) return d
    return dt.toLocaleDateString("en-US", {
      year: "numeric",
      month: "long",
      day: "numeric",
    })
  }

  async function run() {
    if (!query) {
      summary.innerHTML = `<span class="hint">enter a query to search across posts, til, and quotes.</span>`
      return
    }
    if (query.length < 2) {
      summary.innerHTML = `<span class="hint">type at least 2 characters.</span>`
      return
    }

    let pages: PageData[] = []
    try {
      const res = await fetch("/search-data.json")
      pages = await res.json()
    } catch (e) {
      summary.textContent = "failed to load search index."
      return
    }

    const tokens = tokenize(query)
    const scored: ScoredResult[] = pages
      .map(p => ({ ...p, score: score(p, tokens) }))
      .filter(p => p.score > 0)
      .sort((a, b) => {
        if (b.score !== a.score) return b.score - a.score
        const da = a.date ? new Date(a.date).getTime() : 0
        const db = b.date ? new Date(b.date).getTime() : 0
        return db - da
      })

    if (scored.length === 0) {
      summary.innerHTML = `no results for <strong>${escapeHtml(query)}</strong>.`
      resultsEl.innerHTML = `<p class="empty">try fewer or different words.</p>`
      return
    }

    summary.innerHTML = `${scored.length} result${scored.length === 1 ? "" : "s"} for <strong>${escapeHtml(query)}</strong>`

    resultsEl.innerHTML = scored
      .map(p => {
        const section = sectionFromUrl(p.url)
        const date = p.date ? formatDate(p.date) : ""
        const tags = (p.tags || []).slice(0, 6)
        return `
          <div class="result-item">
            <h2><a href="${p.url}">${highlight(p.title, tokens)}</a></h2>
            <div class="result-meta">
              <span class="section">${section}</span>
              ${date ? `<span class="separator">•</span><time>${date}</time>` : ""}
              ${p.category ? `<span class="separator">•</span><span class="category">${escapeHtml(p.category)}</span>` : ""}
              ${
                tags.length
                  ? `<span class="separator">•</span>${tags
                      .map(
                        t => `<span class="tag"><span class="hash">#</span>${escapeHtml(t)}</span>`
                      )
                      .join(" ")}`
                  : ""
              }
            </div>
            <div class="result-excerpt">${highlight(getExcerpt(p.content, tokens), tokens)}</div>
          </div>
        `
      })
      .join("")
  }

  run()
</script>
